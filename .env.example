# SpravPortal WhoCalls API — лучший вариант для продакшена (обходит блокировку парсинга).
# Запросить ключ: api@spravportal.ru или https://www.spravportal.ru/api/whocalls
WHO_CALLS_API_KEY=
WHO_CALLS_API_URL=

# Поисковая эвристика, если API нет: DuckDuckGo → сниппеты SpravPortal/агрегаторов.
# DuckDuckGo часто блокирует Vercel — тогда подключите Serper (бесплатно ~2500 запросов):
# https://serper.dev/
SERPER_API_KEY=

# Отключить поисковую эвристику: ENABLE_SEARCH_FALLBACK=false
ENABLE_SEARCH_FALLBACK=true

# DeepSeek — гопник-комментатор во время проверки (шутки каждые 5 сек).
# Без ключа — встроенные офлайн-приколы.
# Ключ: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
