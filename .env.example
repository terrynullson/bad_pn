# SpravPortal WhoCalls API — рекомендуется для продакшена.
# Запросить ключ: api@spravportal.ru или https://www.spravportal.ru/api/whocalls
WHO_CALLS_API_KEY=
WHO_CALLS_API_URL=

# Поисковая эвристика без API (DuckDuckGo → сниппеты SpravPortal). По умолчанию включена.
# Отключить: ENABLE_SEARCH_FALLBACK=false
ENABLE_SEARCH_FALLBACK=true
